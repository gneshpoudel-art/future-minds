PORT=4000
NODE_ENV=development

# JWT Configuration (use a strong random string for production)
JWT_SECRET=change_this_to_a_long_random_secret_key_at_least_64_chars_in_production
JWT_EXPIRES_IN=7d

# Database – use one of the following:
# Option A: Turso (production)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Option B: Local SQLite file (development, leave TURSO vars empty)
# Leave TURSO_DATABASE_URL and TURSO_AUTH_TOKEN blank to use local SQLite
DB_LOCAL_PATH=./data/futureminds.db

# File uploads
UPLOAD_DIR=./uploads
MAX_IMAGE_SIZE_MB=10
MAX_FILE_SIZE_MB=50

# CORS – Frontend origins (comma-separated for multiple domains)
# For Render: include https://your-app-name.onrender.com
# For local development: http://localhost:8080,http://localhost:5173,http://localhost:4000
CORS_ORIGIN=http://localhost:8080,http://localhost:4000

# Admin credentials (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=FutureMinds@2025!

# Supabase (optional, for storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here
SUPABASE_BUCKET=uploads
CORS_ORIGIN=http://localhost:8080

# Admin default credentials (used during seed only)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=FutureMinds@2025!
